    private void disposeDialog() {
        if (mediaPlayer != null) {
            mediaPlayer.stop();
            mediaPlayer.dispose();
        }
        UploadReelDialog.this.dispose();
    }

    private void setIconFromUrlAsync(javax.swing.JComponent comp, String urlStr, int w, int h) {
        new Thread(() -> {
            try {
                java.awt.Image img = null;
                if (urlStr.startsWith("http")) {
                    java.net.URL url = new java.net.URL(urlStr);
                    img = javax.imageio.ImageIO.read(url);
                } else {
                    java.net.URL localUrl = getClass().getResource(urlStr);
                    if (localUrl != null) img = javax.imageio.ImageIO.read(localUrl);
                }
                if (img != null) {
                    javax.swing.ImageIcon icon = new javax.swing.ImageIcon(img.getScaledInstance(w, h, java.awt.Image.SCALE_SMOOTH));
                    javax.swing.SwingUtilities.invokeLater(() -> {
                        if (comp instanceof javax.swing.JLabel) ((javax.swing.JLabel)comp).setIcon(icon);
                        else if (comp instanceof javax.swing.JButton) ((javax.swing.JButton)comp).setIcon(icon);
                    });
                }
            } catch (Exception e) {}
        }).start();
    }


