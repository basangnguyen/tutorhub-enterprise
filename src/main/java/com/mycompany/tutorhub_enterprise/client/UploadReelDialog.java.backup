        });
        lblCharCount = makeLabel("0/2.200", 12, Font.PLAIN, new Color(0x6B7280));
        captionBottom.add(lblEmoji, BorderLayout.WEST);
        captionBottom.add(lblCharCount, BorderLayout.EAST);
        captionCard.add(captionBottom, BorderLayout.SOUTH);

        txtCaption.getDocument().addDocumentListener(new javax.swing.event.DocumentListener() {
            @Override public void insertUpdate(javax.swing.event.DocumentEvent e) { updateCharCount(); }
            @Override public void removeUpdate(javax.swing.event.DocumentEvent e) { updateCharCount(); }
            @Override public void changedUpdate(javax.swing.event.DocumentEvent e) { updateCharCount(); }
        });

        panel.add(captionCard);
        panel.add(Box.createVerticalStrut(8));

        // Option rows
        JPanel rowLocation = buildOptionRow("map.svg", "Thêm vị trí");
        JLabel lblLocationText = (JLabel) ((JPanel) rowLocation.getComponent(0)).getComponent(1);
        rowLocation.addMouseListener(new MouseAdapter() {
            @Override public void mouseClicked(MouseEvent e) {
                MapPickerDialog dialog = new MapPickerDialog(UploadReelDialog.this);
                dialog.setVisible(true);
                if (dialog.isConfirmed()) {
                    String addr = dialog.getSelectedAddress();
                    if (addr.length() > 30) addr = addr.substring(0, 27) + "...";
                    lblLocationText.setText(addr);
                    lblLocationText.setForeground(TEXT_MAIN);
                }
            }
        });
        panel.add(rowLocation);
        panel.add(Box.createVerticalStrut(4));
        JPanel rowHashtag = new JPanel(new BorderLayout()) {
            @Override protected void paintComponent(Graphics g) {
                Graphics2D g2 = (Graphics2D) g.create();
                g2.setRenderingHint(RenderingHints.KEY_ANTIALIASING, RenderingHints.VALUE_ANTIALIAS_ON);
                g2.setColor(WHITE);
                g2.fillRoundRect(0, 0, getWidth(), getHeight(), 12, 12);
                g2.setColor(new Color(0xD1D5DB));
                g2.setStroke(new BasicStroke(1.5f));
                g2.drawRoundRect(1, 1, getWidth() - 3, getHeight() - 3, 12, 12);
                g2.dispose();
            }
        };
        rowHashtag.setOpaque(false);
        rowHashtag.setBorder(new EmptyBorder(8, 16, 8, 16));
        rowHashtag.setMaximumSize(new Dimension(Integer.MAX_VALUE, 50));

        JPanel leftHashtag = new JPanel(new FlowLayout(FlowLayout.LEFT, 12, 0));
        leftHashtag.setOpaque(false);
        JLabel icnHashtag = makeLabel("", 14, Font.BOLD, PURPLE_MID);
        com.formdev.flatlaf.extras.FlatSVGIcon hashSvg = new com.formdev.flatlaf.extras.FlatSVGIcon("images/icon/hashtag.svg", 20, 20);
        icnHashtag.setIcon(hashSvg);
        leftHashtag.add(icnHashtag);
        rowHashtag.add(leftHashtag, BorderLayout.WEST);

        JTextField txtHashtag = new JTextField();
        txtHashtag.setBorder(null);
        txtHashtag.setOpaque(false);
        txtHashtag.setFont(new Font("Segoe UI", Font.PLAIN, 15));
        txtHashtag.setForeground(new Color(0x9CA3AF));
        txtHashtag.setCaretColor(new Color(0x8B5CF6));
        txtHashtag.setText("Thêm hashtag...");
        
        txtHashtag.addFocusListener(new java.awt.event.FocusAdapter() {
            @Override public void focusGained(java.awt.event.FocusEvent e) {
                if (txtHashtag.getText().equals("Thêm hashtag...")) {
                    txtHashtag.setText("");
                    txtHashtag.setForeground(new Color(0x374151));
                }
            }
            @Override public void focusLost(java.awt.event.FocusEvent e) {
                if (txtHashtag.getText().isEmpty()) {
                    txtHashtag.setText("Thêm hashtag...");
                    txtHashtag.setForeground(new Color(0x9CA3AF));
                    hashtags = "";
                } else {
                    String[] tags = txtHashtag.getText().trim().split("\\s+");
                    hashtags = "";
                    for (String tag : tags) {
                        if (!tag.startsWith("#")) tag = "#" + tag;
                        hashtags += tag + " ";
                    }
                    txtHashtag.setText(hashtags.trim());
                    txtHashtag.setForeground(new Color(0x374151));
                }
            }
        });
        rowHashtag.add(txtHashtag, BorderLayout.CENTER);
        panel.add(rowHashtag);
        panel.add(Box.createVerticalStrut(12));

        // Share section
        // Share section
        JPanel shareHeader = new JPanel(new BorderLayout());
        shareHeader.setOpaque(false);
        shareHeader.setBorder(new EmptyBorder(16, 4, 8, 4));
        shareHeader.setMaximumSize(new Dimension(Integer.MAX_VALUE, 40));
        shareHeader.add(makeLabel("Chia sẻ lên", 15, Font.BOLD, new Color(0x1F2937)), BorderLayout.WEST);
        panel.add(shareHeader);

        // Share account card
        panel.add(buildShareCard());
        panel.add(Box.createVerticalGlue());
        return panel;
    }

    private JPanel buildOptionRow(String iconName, String text) {
        JPanel row = new JPanel(new BorderLayout()) {
            @Override protected void paintComponent(Graphics g) {
                Graphics2D g2 = (Graphics2D) g.create();
                g2.setRenderingHint(RenderingHints.KEY_ANTIALIASING, RenderingHints.VALUE_ANTIALIAS_ON);
                g2.setColor(WHITE);
                g2.fillRoundRect(0, 0, getWidth(), getHeight(), 12, 12);
                g2.setColor(new Color(0xD1D5DB));
                g2.setStroke(new BasicStroke(1.5f));
                g2.drawRoundRect(1, 1, getWidth() - 3, getHeight() - 3, 12, 12);
                g2.dispose();
            }
        };
        row.setOpaque(false);
        row.setBorder(new EmptyBorder(14, 16, 14, 16));
        row.setMaximumSize(new Dimension(Integer.MAX_VALUE, 50));
        row.setCursor(Cursor.getPredefinedCursor(Cursor.HAND_CURSOR));

        JPanel left = new JPanel(new FlowLayout(FlowLayout.LEFT, 12, 0));
        left.setOpaque(false);
        JLabel icn = makeLabel("", 14, Font.BOLD, PURPLE_MID);
        com.formdev.flatlaf.extras.FlatSVGIcon rowSvg = new com.formdev.flatlaf.extras.FlatSVGIcon("images/icon/" + iconName, 20, 20);
        icn.setIcon(rowSvg);
        left.add(icn);
        left.add(makeLabel(text, 14, Font.PLAIN, new Color(0x374151)));
        row.add(left, BorderLayout.WEST);
        row.add(makeLabel(">", 16, Font.BOLD, new Color(0x9CA3AF)), BorderLayout.EAST);
        return row;
    }

    private JPanel buildShareCard() {
        JPanel card = new JPanel(new BorderLayout()) {
            @Override protected void paintComponent(Graphics g) {
                Graphics2D g2 = (Graphics2D) g.create();
                g2.setRenderingHint(RenderingHints.KEY_ANTIALIASING, RenderingHints.VALUE_ANTIALIAS_ON);
                g2.setColor(WHITE);
                g2.fillRoundRect(0, 0, getWidth(), getHeight(), 12, 12);
                g2.setColor(new Color(0xD1D5DB));
                g2.setStroke(new BasicStroke(1.5f));
                g2.drawRoundRect(1, 1, getWidth() - 3, getHeight() - 3, 12, 12);
                g2.dispose();
            }
        };
        card.setOpaque(false);
        card.setBorder(new EmptyBorder(12, 16, 12, 16));
        card.setMaximumSize(new Dimension(Integer.MAX_VALUE, 76));

        // Avatar container with purple ring
        JPanel avatarContainer = new JPanel(new BorderLayout()) {
            @Override protected void paintComponent(Graphics g) {
                Graphics2D g2 = (Graphics2D) g.create();
                g2.setRenderingHint(RenderingHints.KEY_ANTIALIASING, RenderingHints.VALUE_ANTIALIAS_ON);
                g2.setColor(WHITE);
                g2.fillOval(0, 0, getWidth(), getHeight());
                g2.setColor(new Color(0x8B5CF6));
                g2.setStroke(new BasicStroke(1.8f));
                g2.drawOval(1, 1, getWidth() - 3, getHeight() - 3);
                g2.dispose();
                super.paintComponent(g);
            }
        };
        avatarContainer.setOpaque(false);
        avatarContainer.setPreferredSize(new Dimension(52, 52));
        avatarContainer.setMaximumSize(new Dimension(52, 52));
        avatarContainer.setBorder(new EmptyBorder(4, 4, 4, 4));

        JLabel avt = new JLabel() {
            private Image img;
            @Override public void setIcon(Icon icon) {
                if (icon instanceof ImageIcon) {
                    this.img = ((ImageIcon)icon).getImage();
                } else {
                    this.img = null;
                }
                super.setIcon(icon);
            }
            @Override protected void paintComponent(Graphics g) {
                if (getIcon() instanceof ImageIcon && img != null) {
                    Graphics2D g2 = (Graphics2D) g.create();
                    g2.setRenderingHint(RenderingHints.KEY_ANTIALIASING, RenderingHints.VALUE_ANTIALIAS_ON);
                    g2.setClip(new java.awt.geom.Ellipse2D.Float(0, 0, getWidth(), getHeight()));
                    g2.drawImage(img, 0, 0, getWidth(), getHeight(), null);
                    g2.dispose();
                } else {
                    super.paintComponent(g);
                }
            }
        };
        avt.setHorizontalAlignment(SwingConstants.CENTER);
        avatarContainer.add(avt, BorderLayout.CENTER);
        
        JPanel avatarWrapper = new JPanel(new GridBagLayout());
        avatarWrapper.setOpaque(false);
        avatarWrapper.add(avatarContainer);
        
        card.add(avatarWrapper, BorderLayout.WEST);

        JPanel nameCol = new JPanel();
        nameCol.setLayout(new BoxLayout(nameCol, BoxLayout.Y_AXIS));
        nameCol.setOpaque(false);
        nameCol.setBorder(new EmptyBorder(4, 14, 4, 14));
        
        JLabel lblName = makeLabel("Người dùng", 15, Font.BOLD, new Color(0x111827));
        lblName.setAlignmentX(Component.LEFT_ALIGNMENT);
        nameCol.add(lblName);
        
        nameCol.add(Box.createVerticalStrut(4));
        
        JComboBox<String> cbShare = new JComboBox<>(new String[]{"Công khai", "Chỉ mình tôi"});
        cbShare.setFont(new Font("Segoe UI", Font.PLAIN, 12));
        cbShare.setBackground(Color.WHITE);
        cbShare.setFocusable(false);
        cbShare.setSelectedItem("Chỉ mình tôi");
        cbShare.putClientProperty("JComboBox.buttonType", "roundRect");
        cbShare.putClientProperty("JComboBox.padding", new Insets(2, 6, 2, 6));
        cbShare.setAlignmentX(Component.LEFT_ALIGNMENT);
        cbShare.setMaximumSize(new Dimension(110, 26));
        
        nameCol.add(cbShare);
        card.add(nameCol, BorderLayout.CENTER);

        Runnable updateShareUI = () -> {
            String sel = (String) cbShare.getSelectedItem();
            if ("Chỉ mình tôi".equals(sel)) {
                String username = "Người dùng";
                if (getOwner() instanceof MainDashboard) {
                    MainDashboard md = (MainDashboard) getOwner();
                    username = md.getUserName();
                    if (username != null && username.contains("@")) {
                        username = username.split("@")[0];
                    }
                    Image img = md.getAvatar();
                    if (img != null) {
                        avt.setIcon(new ImageIcon(img.getScaledInstance(44, 44, Image.SCALE_SMOOTH)));
                    } else {
                        setIconFromUrlAsync(avt, "https://img.icons8.com/color/96/circled-user-male-skin-type-4--v1.png", 44, 44);
                    }
                } else {
                    setIconFromUrlAsync(avt, "https://img.icons8.com/color/96/circled-user-male-skin-type-4--v1.png", 44, 44);
                }
                lblName.setText(username);
            } else {
                lblName.setText("Mọi người");
                avt.setIcon(null);
                com.formdev.flatlaf.extras.FlatSVGIcon globeIcon = new com.formdev.flatlaf.extras.FlatSVGIcon("images/icon/globe.svg", 44, 44);
                if (globeIcon.hasFound()) avt.setIcon(globeIcon);
            }
        };
        cbShare.addActionListener(e -> updateShareUI.run());
        updateShareUI.run();
        
        return card;
    }

