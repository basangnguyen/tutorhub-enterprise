    /** Renders a toggle switch (pill shape) */
    private JToggleButton makeToggleSwitch(boolean initialOn) {
        JToggleButton toggle = new JToggleButton() {
            @Override protected void paintComponent(Graphics g) {
                Graphics2D g2 = (Graphics2D) g.create();
                g2.setRenderingHint(RenderingHints.KEY_ANTIALIASING, RenderingHints.VALUE_ANTIALIAS_ON);
                Color trackColor = isSelected() ? PURPLE_MAIN : new Color(0xD1D5DB);
                g2.setColor(trackColor);
                g2.fillRoundRect(0, 0, getWidth(), getHeight(), getHeight(), getHeight());
                int thumbX = isSelected() ? getWidth() - getHeight() + 2 : 2;
                g2.setColor(WHITE);
                g2.fillOval(thumbX, 2, getHeight() - 4, getHeight() - 4);
                g2.dispose();
            }
        };
        toggle.setSelected(initialOn);
        toggle.setPreferredSize(new Dimension(44, 24));
        toggle.setContentAreaFilled(false);
        toggle.setBorderPainted(false);
        toggle.setFocusPainted(false);
        toggle.setOpaque(false);
        toggle.setCursor(Cursor.getPredefinedCursor(Cursor.HAND_CURSOR));
        return toggle;
    }

    // ══════════════════════════════════════════════════════════════════════════
    // File selection & validation
    // ══════════════════════════════════════════════════════════════════════════
    private void openFileChooser() {
        JFileChooser chooser = new JFileChooser();
        chooser.setFileFilter(new FileNameExtensionFilter("Video files (MP4, MOV, WEBM)", "mp4", "mov", "webm", "avi"));
        if (chooser.showOpenDialog(this) == JFileChooser.APPROVE_OPTION) {
            handleFileSelected(chooser.getSelectedFile());
        }
    }

    private void handleFileSelected(File f) {
        String name = f.getName().toLowerCase();
        if (!name.endsWith(".mp4") && !name.endsWith(".mov") && !name.endsWith(".webm") && !name.endsWith(".avi")) {
            showFileError("Định dạng không hợp lệ. Vui lòng chọn file MP4, MOV hoặc WEBM.");
            return;
        }
        if (f.length() > 1024L * 1024 * 1024) {
            showFileError("File quá lớn. Kích thước tối đa là 1GB.");
            return;
        }
        selectedFile = f;
        if (lblFileError != null) lblFileError.setVisible(false);
        lblDropInstruction.setText("✅  " + f.getName());
        lblDropSub.setText("Video sẵn sàng để tải lên");
        
        if (jfxPanel != null && selectedFile != null) {
            Platform.runLater(() -> {
                try {
                    String uri = selectedFile.toURI().toString();
                    Media media = new Media(uri);
                    if (mediaPlayer != null) {
                        mediaPlayer.stop();
                        mediaPlayer.dispose();
                    }
                    mediaPlayer = new MediaPlayer(media);
                    mediaPlayer.setAutoPlay(true);
                    mediaDurationSeconds = -1;
                    
                    // Error handler for debugging
                    mediaPlayer.setOnError(() -> {
                        System.err.println("[UploadReelDialog] MediaPlayer error: " + mediaPlayer.getError());
                    });
                    media.setOnError(() -> {
                        System.err.println("[UploadReelDialog] Media error: " + media.getError());
                    });
                    
                    // Extract thumbnails using JCodec - run immediately in background thread
                    new Thread(() -> {
                        try {
                            timelineThumbs.clear();
                            org.jcodec.api.FrameGrab grab = org.jcodec.api.FrameGrab.createFrameGrab(
                                org.jcodec.common.io.NIOUtils.readableChannel(f));
                            
                            // Get duration from JCodec demuxer
                            double jcodecDur = -1;
                            try {
                                org.jcodec.common.DemuxerTrackMeta meta = grab.getVideoTrack().getMeta();
                                if (meta != null && meta.getTotalDuration() > 0) {
                                    jcodecDur = meta.getTotalDuration();
                                    System.out.println("[UploadReelDialog] JCodec duration: " + jcodecDur + "s");
                                }
                            } catch (Exception ex) {
                                System.err.println("[UploadReelDialog] JCodec meta error: " + ex.getMessage());
                            }
                            if (jcodecDur > 0 && mediaDurationSeconds <= 0) {
                                mediaDurationSeconds = jcodecDur;
                            }
                            
                            // Extract first frame for dimensions + thumbnail
                            org.jcodec.common.model.Picture firstPic = null;
                            try {
                                firstPic = grab.getNativeFrame();
                            } catch (Exception ex) {
                                System.err.println("[UploadReelDialog] JCodec first frame error: " + ex.getMessage());
                            }
                            
                            // Use first frame dimensions as fallback for layout
                            final org.jcodec.common.model.Picture fPic = firstPic;
                            if (fPic != null) {
                                final int picW = fPic.getWidth();
                                final int picH = fPic.getHeight();
                                System.out.println("[UploadReelDialog] JCodec frame size: " + picW + "x" + picH);
                                SwingUtilities.invokeLater(() -> {
                                    if (picW > 0 && picH > 0) {
                                        double aspect = (double) picW / picH;
                                        int targetH = 400;
                                        int targetW = (int) (targetH * aspect);
                                        if (targetW > 640) { targetW = 640; targetH = (int) (640 / aspect); }
                                        if (targetW < 280) { targetW = 280; targetH = (int) (280 / aspect); }
                                        
                                        jfxPanel.setPreferredSize(new Dimension(targetW, targetH));
                                        jfxPanel.setMinimumSize(new Dimension(targetW, targetH));
                                        jfxPanel.setMaximumSize(new Dimension(targetW, targetH));
                                        
                                        if (shadow != null) {
                                            // Increase layout room to prevent clipping the video frame
                                            shadow.setPreferredSize(new Dimension(targetW + 420, Math.max(targetH + 260, 600)));
                                            shadow.revalidate();
                                            shadow.repaint();
                                            // Force root dialog repaint to ensure buttons and layers render correctly
                                            SwingUtilities.invokeLater(() -> UploadReelDialog.this.repaint());
                                        }
                                        if (step2VideoContainer != null) {
                                            step2VideoContainer.revalidate();
                                            step2VideoContainer.repaint();
                                        }
                                    }
                                });
                            }
                            
                            // Extract thumbnails
                            double dur = mediaDurationSeconds;
                            if (dur > 0 && !Double.isNaN(dur)) {
                                // Add first frame as thumbnail 0
                                if (fPic != null) {
                                    timelineThumbs.add(org.jcodec.scale.AWTUtil.toBufferedImage(fPic));
                                }
                                // Create a new FrameGrab for seeking (reset position)
                                org.jcodec.api.FrameGrab grab2 = org.jcodec.api.FrameGrab.createFrameGrab(
                                    org.jcodec.common.io.NIOUtils.readableChannel(f));
                                for (int i = (fPic != null ? 1 : 0); i < 6; i++) {
                                    try {
                                        double seekTime = i * (dur / 6.0);
                                        grab2.seekToSecondSloppy(seekTime);
                                        org.jcodec.common.model.Picture pic = grab2.getNativeFrame();
                                        if (pic != null) {
                                            timelineThumbs.add(org.jcodec.scale.AWTUtil.toBufferedImage(pic));
                                        }
                                    } catch (Exception ex) {
                                        System.err.println("[UploadReelDialog] Thumb " + i + " error: " + ex.getMessage());
                                    }
                                }
                                System.out.println("[UploadReelDialog] Extracted " + timelineThumbs.size() + " thumbnails");
                                SwingUtilities.invokeLater(() -> {
                                    if (coverTimeline != null) coverTimeline.repaint();
                                    if (step2VideoContainer != null) {
                                        step2VideoContainer.repaint();
                                        Window win = SwingUtilities.getWindowAncestor(step2VideoContainer);
                                        if (win != null) win.repaint();
                                    }
                                });
                            } else {
                                System.err.println("[UploadReelDialog] No valid duration, skipping thumbnails");
                            }
                        } catch (Exception e) {
                            System.err.println("[UploadReelDialog] extractThumbs fatal error: " + e.getMessage());
                            e.printStackTrace();
                        }
                    }).start();
                    
                    // JavaFX onReady - update layout with accurate dimensions from media
                    mediaPlayer.setOnReady(() -> {
                        System.out.println("[UploadReelDialog] onReady fired. Media size: " + media.getWidth() + "x" + media.getHeight());
                        System.out.println("[UploadReelDialog] onReady duration: " + media.getDuration());
                        
                        double w = media.getWidth();
                        double h = media.getHeight();
                        if (w > 0 && h > 0) {
                            SwingUtilities.invokeLater(() -> {
                                double aspect = w / h;
                                int targetH = 400;
                                int targetW = (int) (targetH * aspect);
                                if (targetW > 640) { targetW = 640; targetH = (int) (640 / aspect); }
                                if (targetW < 280) { targetW = 280; targetH = (int) (280 / aspect); }
                                
                                jfxPanel.setPreferredSize(new Dimension(targetW, targetH));
                                jfxPanel.setMinimumSize(new Dimension(targetW, targetH));
                                jfxPanel.setMaximumSize(new Dimension(targetW, targetH));
                                
                                if (shadow != null) {
                                    // Increase layout room to prevent clipping the video frame
                                    shadow.setPreferredSize(new Dimension(targetW + 420, Math.max(targetH + 260, 600)));
                                    shadow.revalidate();
                                    shadow.repaint();
                                    // Force root dialog repaint to ensure buttons and layers render correctly
                                    SwingUtilities.invokeLater(() -> UploadReelDialog.this.repaint());
                                }
                                if (step2VideoContainer != null) {
                                    step2VideoContainer.revalidate();
                                    step2VideoContainer.repaint();
                                }
                            });
                        }
                        
                        double dur = media.getDuration().toSeconds();
                        if (dur > 0 && !Double.isNaN(dur)) {
                            mediaDurationSeconds = dur;
                        }
                    });
                    
                    // Also listen for duration property changes
                    media.durationProperty().addListener((obs, oldV, newV) -> {
                        double newDur = newV.toSeconds();
                        System.out.println("[UploadReelDialog] durationProperty changed: " + newDur + "s");
                        if (newDur > 0 && !Double.isNaN(newDur)) {
                            if (mediaDurationSeconds <= 0) {
                                mediaDurationSeconds = newDur;
                            }
                        }
                    });
                    
                    mediaPlayer.setOnError(() -> {
                        System.out.println("Media error: " + mediaPlayer.getError());
                    });
                    
                    mediaView = new MediaView(mediaPlayer);
                    mediaView.setPreserveRatio(true);
                    
                    coverFxView = new javafx.scene.image.ImageView();
                    coverFxView.setPreserveRatio(true);
                    coverFxView.setVisible(false);
                    
                    // Use BorderPane overlay for bottom bar only - no center play button

                    // Bottom Bar - mimic ReelsTabPanel approach
                    javafx.scene.layout.HBox bottomOverlay = new javafx.scene.layout.HBox(12);
                    bottomOverlay.setStyle("-fx-padding: 8px 14px 12px 14px; -fx-background-color: linear-gradient(to top, rgba(0,0,0,0.75) 0%, transparent 100%);");
                    bottomOverlay.setAlignment(javafx.geometry.Pos.CENTER);

                    // Play/Pause button
                    fxBtnPlay = new javafx.scene.control.Label("⏸");
                    fxBtnPlay.setTextFill(javafx.scene.paint.Color.WHITE);
                    fxBtnPlay.setFont(javafx.scene.text.Font.font("Segoe UI", 18));
                    fxBtnPlay.setCursor(javafx.scene.Cursor.HAND);
                    fxBtnPlay.setMinWidth(javafx.scene.layout.Region.USE_PREF_SIZE);
                    // No volume button as per ReelsTabPanel
                    
                    // Time label
                    fxLblTime = new javafx.scene.control.Label("0:00 / 0:00");
                    fxLblTime.setTextFill(javafx.scene.paint.Color.WHITE);
                    fxLblTime.setFont(javafx.scene.text.Font.font("Segoe UI", javafx.scene.text.FontWeight.BOLD, 12));
                    fxLblTime.setMinWidth(javafx.scene.layout.Region.USE_PREF_SIZE);

                    // Progress bar wrapper (same as ReelsTabPanel)
                    StackPane pbWrapper = new StackPane();
                    pbWrapper.setAlignment(javafx.geometry.Pos.CENTER_LEFT);
                    javafx.scene.layout.HBox.setHgrow(pbWrapper, javafx.scene.layout.Priority.ALWAYS);
                    pbWrapper.setMaxWidth(Double.MAX_VALUE);
                    pbWrapper.setCursor(javafx.scene.Cursor.HAND);

                    javafx.scene.control.ProgressBar pb = new javafx.scene.control.ProgressBar(0);
                    pb.setMaxWidth(Double.MAX_VALUE);
                    pb.setPrefHeight(4);
                    pb.setStyle("-fx-accent: #8B5CF6; -fx-control-inner-background: rgba(255,255,255,0.35); -fx-background-color: rgba(255,255,255,0.35); -fx-background-radius: 4px; -fx-padding: 0;");
                    pb.setMouseTransparent(true);

                    javafx.scene.canvas.Canvas pbCanvas = new javafx.scene.canvas.Canvas();
                    pbCanvas.setMouseTransparent(true);
                    pbCanvas.widthProperty().bind(pbWrapper.widthProperty());
                    pbCanvas.heightProperty().set(5);
                    pb.progressProperty().addListener((obs, ov, nv) -> {
                        double w = pbCanvas.getWidth();
                        double h = pbCanvas.getHeight();
                        double prog = nv.doubleValue();
                        javafx.scene.canvas.GraphicsContext gc = pbCanvas.getGraphicsContext2D();
                        gc.clearRect(0, 0, w, h);
                        gc.setFill(javafx.scene.paint.Color.rgb(255, 255, 255, 0.30));
                        gc.fillRoundRect(0, 1, w, 4, 4, 4);
                        gc.setFill(javafx.scene.paint.Color.rgb(139, 92, 246, 1.0));
                        gc.fillRoundRect(0, 1, w * Math.max(0, Math.min(1, prog)), 4, 4, 4);
                    });
                    pb.setVisible(false);

                    javafx.scene.shape.Circle pbThumb = new javafx.scene.shape.Circle(6, javafx.scene.paint.Color.WHITE);
                    pbThumb.setMouseTransparent(true);
                    pbThumb.setVisible(false);
                    pbThumb.translateXProperty().bind(pb.progressProperty().multiply(pbWrapper.widthProperty().subtract(12)));

                    pbWrapper.getChildren().addAll(pb, pbCanvas, pbThumb);

                    pbWrapper.setOnMouseEntered(e -> { pbCanvas.heightProperty().set(7); pbThumb.setVisible(true); });
                    pbWrapper.setOnMouseExited(e -> { pbCanvas.heightProperty().set(5); pbThumb.setVisible(false); });
                    pbWrapper.setOnMousePressed(e -> {
                        if (mediaPlayer != null) {
                            double pct = Math.max(0, Math.min(1, e.getX() / pbWrapper.getWidth()));
                            pb.setProgress(pct);
                            if (mediaDurationSeconds > 0) mediaPlayer.seek(javafx.util.Duration.seconds(mediaDurationSeconds * pct));
                        }
                    });
                    pbWrapper.setOnMouseDragged(e -> {
                        if (mediaPlayer != null) {
                            double pct = Math.max(0, Math.min(1, e.getX() / pbWrapper.getWidth()));
                            pb.setProgress(pct);
                            if (mediaDurationSeconds > 0) mediaPlayer.seek(javafx.util.Duration.seconds(mediaDurationSeconds * pct));
                        }
                    });

                    bottomOverlay.getChildren().addAll(fxBtnPlay, fxLblTime, pbWrapper);
                    
                    
                    Runnable togglePlay = () -> {
                        if (mediaPlayer != null) {
                            if (mediaPlayer.getStatus() == MediaPlayer.Status.PLAYING) {
                                mediaPlayer.pause();
                                fxBtnPlay.setText("▶");
                                if (isCustomCover && customCoverImg != null && coverFxView != null) {
                                    coverFxView.setVisible(true);
                                } else if (!isCustomCover && mediaDurationSeconds > 0) {
                                    mediaPlayer.seek(javafx.util.Duration.seconds(mediaDurationSeconds * coverPct));
                                }
                            } else {
                                mediaPlayer.play();
                                fxBtnPlay.setText("⏸");
                                if (coverFxView != null) coverFxView.setVisible(false);
                            }
                        }
                    };
                    fxBtnPlay.setOnMouseClicked(e -> togglePlay.run());
                    mediaView.setOnMouseClicked(e -> togglePlay.run());
                    if (coverFxView != null) coverFxView.setOnMouseClicked(e -> togglePlay.run());
                    // Mute logic removed
                    
                    mediaPlayer.currentTimeProperty().addListener((obs, oldV, newV) -> {
                        double total = mediaDurationSeconds;
                        if (total > 0 && Double.isFinite(total)) {
                            double cur = newV.toSeconds();
                            pb.setProgress(cur / total);
                            String curStr = String.format("%d:%02d", (int)(cur/60), (int)(cur%60));
                            String totStr = String.format("%d:%02d", (int)(total/60), (int)(total%60));
                            fxLblTime.setText(curStr + " / " + totStr);
                        }
                    });
                    mediaPlayer.totalDurationProperty().addListener((obs, oldV, newV) -> {
                        double total = newV.toSeconds();
                        if (total > 0 && Double.isFinite(total)) {
                            mediaDurationSeconds = total;
                            double cur = mediaPlayer.getCurrentTime().toSeconds();
                            String curStr = String.format("%d:%02d", (int)(cur/60), (int)(cur%60));
                            String totStr = String.format("%d:%02d", (int)(total/60), (int)(total%60));
                            fxLblTime.setText(curStr + " / " + totStr);
                            SwingUtilities.invokeLater(() -> {
                                if (step2VideoContainer != null) {
                                    step2VideoContainer.repaint();
                                    Window w = SwingUtilities.getWindowAncestor(step2VideoContainer);
                                    if (w != null) w.repaint();
                                }
                            });
                        }
                    });
                    
                    // Use BorderPane overlay: bottom bar auto-fills full width
                    javafx.scene.layout.BorderPane overlay = new javafx.scene.layout.BorderPane();
                    overlay.setStyle("-fx-background-color: transparent;");
                    overlay.setPickOnBounds(false); // Let clicks pass through empty areas
                    overlay.setBottom(bottomOverlay);
                    // Click on video to toggle play
                    mediaView.setOnMouseClicked(e -> togglePlay.run());
                    coverFxView.setOnMouseClicked(e -> togglePlay.run());
                    
                    StackPane root = new StackPane();
                    root.setStyle("-fx-background-color: #1C1C1E;");
                    javafx.scene.shape.Rectangle clip = new javafx.scene.shape.Rectangle();
                    clip.widthProperty().bind(root.widthProperty());
                    clip.heightProperty().bind(root.heightProperty());
                    clip.setArcWidth(32);
                    clip.setArcHeight(32);
                    root.setClip(clip);
                    root.getChildren().addAll(mediaView, coverFxView, overlay);
                    root.setOnMouseClicked(e -> togglePlay.run());

                    Scene scene = new Scene(root);
                    mediaView.fitWidthProperty().bind(scene.widthProperty());
                    mediaView.fitHeightProperty().bind(scene.heightProperty());
                    coverFxView.fitWidthProperty().bind(scene.widthProperty());
                    coverFxView.fitHeightProperty().bind(scene.heightProperty());
                    jfxPanel.setScene(scene);
                    
                } catch (Exception ex) {
                    ex.printStackTrace();
                }
            });
        }
        
        Timer t = new Timer(400, e -> goTo("step2"));
        t.setRepeats(false);
        t.start();
    }
private void showFileError(String msg) {
        lblFileError.setText(msg);
        lblFileError.setVisible(true);
    }

    private void updateCharCount() {
        int len = getCaptionText().length();
        lblCharCount.setText(len + "/2.200");
    }

    public String getCaptionText() {
        if (txtCaption == null) return "";
        StringBuilder sb = new StringBuilder();
        javax.swing.text.StyledDocument doc = txtCaption.getStyledDocument();
        for (int i = 0; i < doc.getLength(); i++) {
            javax.swing.text.Element el = doc.getCharacterElement(i);
            javax.swing.Icon icon = javax.swing.text.StyleConstants.getIcon(el.getAttributes());
            if (icon instanceof EmojiIcon) {
                sb.append(((EmojiIcon)icon).getTag());
            } else {
                try { sb.append(doc.getText(i, 1)); } catch (Exception e) {}
            }
        }
        String text = sb.toString();
        if ("Viết chú thích cho thước phim...".equals(text)) return "";
        return text;
    }

    private void goTo(String step) {
        try {
            if ("step3".equals(step)) {
                if (step3VideoContainer != null && jfxPanel != null) {
                    // Remove jfxPanel from its current parent first
                    java.awt.Container oldParent = jfxPanel.getParent();
                    if (oldParent != null) {
                        oldParent.remove(jfxPanel);
                        oldParent.revalidate();
                        oldParent.repaint();
                    }
                    // Add to step3 container (OverlayLayout - use simple add, not indexed)
                    step3VideoContainer.add(jfxPanel);
                    step3VideoContainer.revalidate();
                    step3VideoContainer.repaint();
                    Platform.runLater(() -> {
                        try {
                            if (mediaPlayer != null) {
                                if (mediaDurationSeconds > 0) {
                                    mediaPlayer.setStartTime(javafx.util.Duration.seconds(mediaDurationSeconds * trimStartPct));
                                    mediaPlayer.setStopTime(javafx.util.Duration.seconds(mediaDurationSeconds * trimEndPct));
                                    mediaPlayer.seek(javafx.util.Duration.seconds(mediaDurationSeconds * trimStartPct));
                                }
                                mediaPlayer.setCycleCount(MediaPlayer.INDEFINITE);
                                mediaPlayer.play();
                            }
                        } catch (Exception ex) {
                            ex.printStackTrace();
                        }
                    });
                }
            } else if ("step2".equals(step)) {
                if (step2VideoContainer != null && jfxPanel != null) {
                    java.awt.Container oldParent = jfxPanel.getParent();
                    if (oldParent != null) {
                        oldParent.remove(jfxPanel);
                        oldParent.revalidate();
                        oldParent.repaint();
                    }
                    step2VideoContainer.add(jfxPanel, BorderLayout.CENTER);
                    step2VideoContainer.revalidate();
                    step2VideoContainer.repaint();
                    Platform.runLater(() -> {
                        if (mediaPlayer != null) {
                            mediaPlayer.setStartTime(javafx.util.Duration.ZERO);
                            if (mediaPlayer.getMedia() != null) {
                                mediaPlayer.setStopTime(mediaPlayer.getMedia().getDuration());
                            }
                            mediaPlayer.setCycleCount(1);
                        }
                    });
                }
            }
            SwingUtilities.invokeLater(() -> cardLayout.show(cardPanel, step));
        } catch (Exception ex) {
            ex.printStackTrace();
            // Ensure card still switches even if video operations fail
            SwingUtilities.invokeLater(() -> cardLayout.show(cardPanel, step));
        }
    }

    // ══════════════════════════════════════════════════════════════════════════
    // Public API for ReelsTabPanel
    // ══════════════════════════════════════════════════════════════════════════
    public boolean isApproved()    { return isApproved; }
    public File   getSelectedFile(){ return selectedFile; }
    public String getCaption()     { return caption; }
    public String getHashtags()    { return hashtags; }

    class EmojiIcon extends ImageIcon {
        private String tag;
        public EmojiIcon(URL url, String tag) {
            super(new ImageIcon(url).getImage().getScaledInstance(20, 20, Image.SCALE_SMOOTH));
            this.tag = tag;
        }
        public String getTag() { return tag; }
    }

    class EmojiCategory {
        String title;
        String prefix;
        String navIconUrl;
        public EmojiCategory(String title, String prefix, String navIconUrl) { 
            this.title = title; this.prefix = prefix; this.navIconUrl = navIconUrl;
        }
    }

    private void showEmojiPicker(Component invoker) {
        JPopupMenu emojiPopup = new JPopupMenu();
        emojiPopup.setBackground(Color.WHITE);
        emojiPopup.setBorder(BorderFactory.createLineBorder(Color.decode("#E5E7EB"), 1));
        
        EmojiCategory[] categories = {
            new EmojiCategory("Cảm xúc", "mat", "https://img.icons8.com/fluency-systems-regular/48/64748B/happy.png"),
            new EmojiCategory("Cử chỉ", "cuchi", "https://img.icons8.com/fluency-systems-regular/48/64748B/hand.png"),
            new EmojiCategory("Con người", "connguoi", "https://img.icons8.com/fluency-systems-regular/48/64748B/user.png"),
            new EmojiCategory("Tự nhiên", "tunhien", "https://img.icons8.com/fluency-systems-regular/48/64748B/deciduous-tree.png"),
            new EmojiCategory("Con vật", "convat", "https://img.icons8.com/fluency-systems-regular/48/64748B/cat-profile.png"),
            new EmojiCategory("Trang trí", "trangtri", "https://img.icons8.com/fluency-systems-regular/48/64748B/party-baloon.png"),
            new EmojiCategory("Ăn uống", "anuong", "https://img.icons8.com/fluency-systems-regular/48/64748B/hamburger.png"), 
            new EmojiCategory("Trò chơi", "trochoi", "https://img.icons8.com/fluency-systems-regular/48/64748B/football2.png"),
            new EmojiCategory("Công cụ", "congcu", "https://img.icons8.com/fluency-systems-regular/48/64748B/light.png"),
            new EmojiCategory("Cờ", "co", "https://img.icons8.com/fluency-systems-regular/48/64748B/flag.png")
        };

        JPanel mainScrollContent = new JPanel();
        mainScrollContent.setLayout(new BoxLayout(mainScrollContent, BoxLayout.Y_AXIS));
        mainScrollContent.setBackground(Color.WHITE);
        mainScrollContent.setBorder(new EmptyBorder(5, 10, 10, 10));

        if (!recentEmojis.isEmpty()) {
            mainScrollContent.add(createEmojiSectionTitle("Gần đây"));
            JPanel recentGrid = new JPanel(new GridLayout(0, 8, 2, 6)); 
            recentGrid.setBackground(Color.WHITE);
            for (String tag : recentEmojis) {
                recentGrid.add(createSingleEmojiButton(tag, emojiPopup));
            }
            int fill = 8 - (recentEmojis.size() % 8);
            if (fill < 8) for(int i=0; i<fill; i++) { JPanel p = new JPanel(); p.setOpaque(false); recentGrid.add(p); }
            
            JPanel wrap = new JPanel(new BorderLayout()); wrap.setOpaque(false); wrap.add(recentGrid, BorderLayout.WEST);
            mainScrollContent.add(wrap);
            mainScrollContent.add(Box.createVerticalStrut(10));
        }

        java.util.Map<String, JPanel> categoryPanels = new java.util.HashMap<>();

        for (EmojiCategory cat : categories) {
            JPanel titlePanel = createEmojiSectionTitle(cat.title);
            categoryPanels.put(cat.prefix, titlePanel); 
            mainScrollContent.add(titlePanel);
            
            JPanel gridPanel = new JPanel(new GridLayout(0, 8, 2, 6)); 
            gridPanel.setBackground(Color.WHITE);
            
            int missingCount = 0;
            for (int i = 1; i <= 200; i++) {
                String path = "/images/emoji/" + cat.prefix + "/" + cat.prefix + " (" + i + ").png";
                URL url = getClass().getResource(path);
                
                if (url == null) {
                    missingCount++;
                    if (missingCount > 15) break;
                    continue; 
                }
                missingCount = 0; 
                
                String tag = "[e:" + cat.prefix + ":" + i + "]";
                gridPanel.add(createSingleEmojiButton(tag, emojiPopup));
            }
            
            JPanel alignLeftWrap = new JPanel(new BorderLayout()); 
            alignLeftWrap.setOpaque(false); 
            alignLeftWrap.add(gridPanel, BorderLayout.WEST);
            
            mainScrollContent.add(alignLeftWrap);
            mainScrollContent.add(Box.createVerticalStrut(15));
        }

        JScrollPane scrollPane = new JScrollPane(mainScrollContent);
        scrollPane.setBorder(null);
        scrollPane.setPreferredSize(new Dimension(320, 260)); 
        scrollPane.getVerticalScrollBar().setUnitIncrement(25);
        scrollPane.setHorizontalScrollBarPolicy(JScrollPane.HORIZONTAL_SCROLLBAR_NEVER);

        JPanel bottomNav = new JPanel();
        bottomNav.setLayout(new BoxLayout(bottomNav, BoxLayout.X_AXIS)); 
        bottomNav.setBackground(Color.WHITE);
        bottomNav.setBorder(new EmptyBorder(4, 4, 4, 4));
        
        bottomNav.add(createNavIconButton("https://img.icons8.com/fluency-systems-regular/48/2563EB/time.png", () -> {
            scrollPane.getViewport().setViewPosition(new Point(0, 0));
        }));
        bottomNav.add(Box.createHorizontalStrut(6));

        for (EmojiCategory cat : categories) {
            bottomNav.add(createNavIconButton(cat.navIconUrl, () -> {
                JPanel target = categoryPanels.get(cat.prefix);
                if (target != null) {
                    SwingUtilities.invokeLater(() -> scrollPane.getViewport().setViewPosition(new Point(0, target.getY())));
                }
            }));
            bottomNav.add(Box.createHorizontalStrut(6));
        }
        
        JScrollPane bottomScroll = new JScrollPane(bottomNav);
        bottomScroll.setBorder(BorderFactory.createMatteBorder(1, 0, 0, 0, Color.decode("#E5E7EB")));
        bottomScroll.setVerticalScrollBarPolicy(JScrollPane.VERTICAL_SCROLLBAR_NEVER);
        bottomScroll.setHorizontalScrollBarPolicy(JScrollPane.HORIZONTAL_SCROLLBAR_AS_NEEDED);
        bottomScroll.getHorizontalScrollBar().setPreferredSize(new Dimension(0, 6));
        bottomScroll.setPreferredSize(new Dimension(320, 46));

        bottomScroll.addMouseWheelListener(e -> {
            if (e.getScrollType() == java.awt.event.MouseWheelEvent.WHEEL_UNIT_SCROLL) {
                JScrollBar hBar = bottomScroll.getHorizontalScrollBar();
                hBar.setValue(hBar.getValue() + e.getUnitsToScroll() * 20); 
            }
        });

        JPanel container = new JPanel(new BorderLayout());
        container.setBackground(Color.WHITE);
        container.add(scrollPane, BorderLayout.CENTER);
        container.add(bottomScroll, BorderLayout.SOUTH);

        emojiPopup.add(container);
        emojiPopup.show(invoker, -280, 20); 
    }

    private JPanel createEmojiSectionTitle(String text) {
        JPanel p = new JPanel(new FlowLayout(FlowLayout.LEFT, 5, 5));
        p.setBackground(Color.WHITE);
        JLabel lbl = new JLabel(text);
        lbl.setFont(new Font("Segoe UI", Font.BOLD, 13));
        lbl.setForeground(Color.decode("#374151"));
        p.add(lbl);
        return p;
    }

    private JLabel createSingleEmojiButton(String tag, JPopupMenu popup) {
        JLabel lbl = new JLabel("", SwingConstants.CENTER);
        lbl.setPreferredSize(new Dimension(34, 34));
        lbl.setCursor(new Cursor(Cursor.HAND_CURSOR));
        
        try {
            java.util.regex.Matcher m = java.util.regex.Pattern.compile("\\[e:([a-zA-Z0-9_]+):(\\d+)\\]").matcher(tag);
            if (m.find()) {
                String prefix = m.group(1);
                String num = m.group(2);
                URL url = getClass().getResource("/images/emoji/" + prefix + "/" + prefix + " (" + num + ").png");
                if (url != null) lbl.setIcon(new ImageIcon(new ImageIcon(url).getImage().getScaledInstance(26, 26, Image.SCALE_SMOOTH)));
            }
        } catch (Exception e) {}

        lbl.addMouseListener(new MouseAdapter() {
            @Override public void mouseEntered(MouseEvent e) { lbl.setOpaque(true); lbl.setBackground(Color.decode("#F1F5F9")); lbl.repaint(); }
            @Override public void mouseExited(MouseEvent e) { lbl.setOpaque(false); lbl.repaint(); }
            @Override public void mouseClicked(MouseEvent e) {
                EmojiIcon emojiIcon = null;
                try {
                    java.util.regex.Matcher m = java.util.regex.Pattern.compile("\\[e:([a-zA-Z0-9_]+):(\\d+)\\]").matcher(tag);
                    if (m.find()) {
                        String prefix = m.group(1);
                        String num = m.group(2);
                        URL url = getClass().getResource("/images/emoji/" + prefix + "/" + prefix + " (" + num + ").png");
                        if (url != null) emojiIcon = new EmojiIcon(url, tag);
                    }
                } catch (Exception ex) {}
                
                if (emojiIcon != null) {
                    txtCaption.insertIcon(emojiIcon);
                } else {
                    txtCaption.replaceSelection(tag);
                }
                txtCaption.requestFocus();
                
                recentEmojis.remove(tag); 
                recentEmojis.add(0, tag); 
                if (recentEmojis.size() > 16) recentEmojis.remove(16); 
                
                popup.setVisible(false);
            }
        });
        return lbl;
    }

    private JPanel createNavIconButton(String iconUrl, Runnable onClick) {
        JPanel p = new JPanel(new BorderLayout());
        p.setBackground(Color.WHITE);
        p.setPreferredSize(new Dimension(32, 32));
        p.setCursor(new Cursor(Cursor.HAND_CURSOR));
        
        JLabel lbl = new JLabel("", SwingConstants.CENTER);
        setIconFromUrlAsync(lbl, iconUrl, 18, 18);
        p.add(lbl, BorderLayout.CENTER);
        
        p.addMouseListener(new MouseAdapter() {
            @Override public void mouseEntered(MouseEvent e) { p.setBackground(Color.decode("#F1F5F9")); }
            @Override public void mouseExited(MouseEvent e) { p.setBackground(Color.WHITE); }
            @Override public void mouseClicked(MouseEvent e) { onClick.run(); }
        });
        return p;
    }
}
