        bar.add(right, BorderLayout.EAST);

        return bar;
    }

    private JPanel buildTimeline() {
        JPanel timeline = new JPanel() {
            @Override protected void paintComponent(Graphics g) {
                super.paintComponent(g);
                Graphics2D g2 = (Graphics2D) g.create();
                // Explicitly clear background to prevent trails (smudges)
                g2.setColor(Color.WHITE);
                g2.fillRect(0, 0, getWidth(), getHeight());
                
                g2.setRenderingHint(RenderingHints.KEY_ANTIALIASING, RenderingHints.VALUE_ANTIALIAS_ON);
                
                int trackH = 60;
                int padding = 16;
                int trackW = getWidth() - padding * 2;
                
                // Background
                g2.setColor(new Color(243, 244, 246));
                g2.fillRoundRect(0, 0, getWidth(), trackH, 16, 16);
                
                // Thumbs
                if (!timelineThumbs.isEmpty()) {
                    int thumbW = trackW / timelineThumbs.size();
                    g2.setClip(new java.awt.geom.RoundRectangle2D.Float(padding, 0, trackW, trackH, 16, 16));
                    for (int i = 0; i < timelineThumbs.size(); i++) {
                        g2.drawImage(timelineThumbs.get(i), padding + i * thumbW, 0, thumbW, trackH, null);
                    }
                    g2.setClip(null);
                }
                
                // Dim areas outside trims
                g2.setClip(new java.awt.geom.RoundRectangle2D.Float(padding, 0, trackW, trackH, 16, 16));
                g2.setColor(new Color(0, 0, 0, 150));
                int startX = padding + (int)(trimStartPct * trackW);
                int endX = padding + (int)(trimEndPct * trackW);
                g2.fillRect(padding, 0, startX - padding, trackH);
                g2.fillRect(endX, 0, (padding + trackW) - endX, trackH);
                g2.setClip(null);
                
                // CapCut style trimmer
                int hw = 12; // handle width
                
                // Black outline behind
                g2.setColor(new Color(0, 0, 0, 80));
                g2.fillRoundRect(startX - hw - 1, -2, hw + 2, trackH + 4, 8, 8);
                g2.fillRoundRect(endX - 1, -2, hw + 2, trackH + 4, 8, 8);
                g2.setStroke(new BasicStroke(4f));
                g2.drawLine(startX, 1, endX, 1);
                g2.drawLine(startX, trackH - 1, endX, trackH - 1);
                
                // White foreground
                g2.setColor(WHITE);
                g2.fillRoundRect(startX - hw, -1, hw, trackH + 2, 8, 8);
                g2.fillRect(startX - hw/2, -1, hw/2, trackH + 2); // square right edge
                
                g2.fillRoundRect(endX, -1, hw, trackH + 2, 8, 8);
                g2.fillRect(endX, -1, hw/2, trackH + 2); // square left edge
                
                g2.setStroke(new BasicStroke(2f));
                g2.drawLine(startX, 1, endX, 1); // top border
                g2.drawLine(startX, trackH - 1, endX, trackH - 1); // bottom border
                
                g2.setColor(new Color(107, 114, 128)); // Darker gray for inner lines
                g2.setStroke(new BasicStroke(1.5f));
                g2.drawLine(startX - 8, trackH/2 - 4, startX - 8, trackH/2 + 4);
                g2.drawLine(startX - 4, trackH/2 - 4, startX - 4, trackH/2 + 4);
                g2.drawLine(endX + 4, trackH/2 - 4, endX + 4, trackH/2 + 4);
                g2.drawLine(endX + 8, trackH/2 - 4, endX + 8, trackH/2 + 4);
                
                // Playhead
                if (mediaPlayer != null && mediaPlayer.getTotalDuration().toMillis() > 0) {
                    double progress = mediaPlayer.getCurrentTime().toMillis() / mediaPlayer.getTotalDuration().toMillis();
                    int px = padding + (int)(progress * trackW);
                    g2.setColor(WHITE);
                    g2.fillRect(px, 0, 3, trackH);
                    g2.fillRoundRect(px - 4, -4, 11, 8, 4, 4);
                }
                
                // Draw time labels: left handle time and right handle time only
                if (mediaPlayer != null) {
                    double dur = mediaPlayer.getTotalDuration().toSeconds();
                    if (dur > 0) {
                        double startSec = trimStartPct * dur;
                        double endSec = trimEndPct * dur;
                        String sTime = String.format("%d:%02d", (int)(startSec/60), (int)(startSec%60));
                        String eTime = String.format("%d:%02d", (int)(endSec/60), (int)(endSec%60));
                        
                        g2.setFont(new Font("Segoe UI", Font.PLAIN, 12));
                        g2.setColor(new Color(82, 82, 91)); // Subtle gray, elegant
                        
                        // Left time below left handle
                        int leftLabelX = startX - 16;
                        g2.drawString(sTime, Math.max(0, leftLabelX), trackH + 20);
                        
                        // Right time below right handle
                        int rightLabelX = endX;
                        java.awt.FontMetrics fm = g2.getFontMetrics();
                        int rightW = fm.stringWidth(eTime);
                        g2.drawString(eTime, Math.min(rightLabelX, getWidth() - rightW - 2), trackH + 20);
                    }
                }
                
                g2.dispose();
            }
        };
        timeline.setPreferredSize(new Dimension(0, 80)); // 60 for track + 20 for labels
        
        timeline.addMouseListener(new MouseAdapter() {
            @Override public void mousePressed(MouseEvent e) {
                int padding = 16;
                int trackW = timeline.getWidth() - padding * 2;
                int startX = padding + (int)(trimStartPct * trackW);
                int endX = padding + (int)(trimEndPct * trackW);
                
                if (mediaPlayer != null && mediaPlayer.getTotalDuration().toMillis() > 0) {
                    double progress = mediaPlayer.getCurrentTime().toMillis() / mediaPlayer.getTotalDuration().toMillis();
                    int px = padding + (int)(progress * trackW);
                    if (Math.abs(e.getX() - px) <= 10) {
                        isDraggingPlayhead = true;
                        if(mediaPlayer.getStatus() == MediaPlayer.Status.PLAYING) mediaPlayer.pause();
                        return;
                    }
                }
                if (Math.abs(e.getX() - startX) <= 15) { isDraggingStart = true; }
                else if (Math.abs(e.getX() - endX) <= 15) { isDraggingEnd = true; }
            }
            @Override public void mouseReleased(MouseEvent e) {
                if (isDraggingPlayhead && mediaPlayer != null && fxBtnPlay != null) {
                    mediaPlayer.play();
                }
                isDraggingStart = false;
                isDraggingEnd = false;
                isDraggingPlayhead = false;
            }
        });
        
        timeline.addMouseMotionListener(new MouseAdapter() {
            @Override public void mouseDragged(MouseEvent e) {
                int padding = 16;
                int trackW = timeline.getWidth() - padding * 2;
                double pct = (double)(e.getX() - padding) / trackW;
                pct = Math.max(0, Math.min(1, pct));
                
                if (isDraggingStart) {
                    trimStartPct = Math.min(pct, trimEndPct - 0.05); // min 5% duration
                    timeline.repaint();
                    if (mediaPlayer != null) mediaPlayer.seek(mediaPlayer.getTotalDuration().multiply(trimStartPct));
                } else if (isDraggingEnd) {
                    trimEndPct = Math.max(pct, trimStartPct + 0.05);
                    timeline.repaint();
                    if (mediaPlayer != null) mediaPlayer.seek(mediaPlayer.getTotalDuration().multiply(trimEndPct));
                } else if (isDraggingPlayhead) {
                    if (mediaPlayer != null) {
                        mediaPlayer.seek(mediaPlayer.getTotalDuration().multiply(pct));
                        timeline.repaint();
                    }
                }
            }
        });
        
        Timer t = new Timer(50, e -> {
            if (mediaPlayer != null && mediaPlayer.getStatus() == MediaPlayer.Status.PLAYING) {
                double progress = mediaPlayer.getCurrentTime().toMillis() / mediaPlayer.getTotalDuration().toMillis();
                if (progress >= trimEndPct) {
                    mediaPlayer.seek(mediaPlayer.getTotalDuration().multiply(trimStartPct));
                }
                timeline.repaint();
            }
        });
        t.start();
        
        JPanel wrap = new JPanel(new BorderLayout());
        wrap.setOpaque(false);
        wrap.add(timeline, BorderLayout.CENTER);
        return wrap;
    }

        // Combine Cover and Audio inside ONE panel
    private JPanel buildEditSettings() {
        JPanel panel = new JPanel() {
            @Override public Dimension getPreferredSize() {
                Dimension d = super.getPreferredSize();
                return new Dimension(320, d.height);
            }
        };
        panel.setLayout(new BoxLayout(panel, BoxLayout.Y_AXIS));
        panel.setOpaque(false);
        panel.setBorder(new EmptyBorder(16, 16, 16, 16));
        
        JPanel bgPanel = new JPanel(new BorderLayout()) {
            @Override protected void paintComponent(Graphics g) {
                Graphics2D g2 = (Graphics2D) g.create();
                g2.setRenderingHint(RenderingHints.KEY_ANTIALIASING, RenderingHints.VALUE_ANTIALIAS_ON);
                g2.setColor(WHITE);
                g2.fillRoundRect(0, 0, getWidth(), getHeight(), 12, 12);
                g2.setColor(BORDER_LIGHT);
                g2.drawRoundRect(0, 0, getWidth() - 1, getHeight() - 1, 12, 12);
                g2.dispose();
            }
        };
        bgPanel.setOpaque(false);
        bgPanel.add(panel, BorderLayout.CENTER);

        JLabel lblCover = makeLabel("Ảnh bìa", 15, Font.PLAIN, TEXT_MAIN);
        lblCover.setAlignmentX(Component.LEFT_ALIGNMENT);
        panel.add(lblCover);
        panel.add(Box.createVerticalStrut(10));
        
        // Instagram-style Cover Timeline
        coverTimeline = new JPanel() {
            @Override protected void paintComponent(Graphics g) {
                Graphics2D g2 = (Graphics2D) g.create();
                g2.setRenderingHint(RenderingHints.KEY_ANTIALIASING, RenderingHints.VALUE_ANTIALIAS_ON);
                if (timelineThumbs.isEmpty()) {
                    g2.setColor(new Color(243, 244, 246));
                    g2.fillRoundRect(0, 0, getWidth(), getHeight(), 8, 8);
                } else {
                    int thumbW = getWidth() / timelineThumbs.size();
                    g2.setClip(new java.awt.geom.RoundRectangle2D.Float(0, 0, getWidth(), getHeight(), 8, 8));
                    for (int i = 0; i < timelineThumbs.size(); i++) {
                        g2.drawImage(timelineThumbs.get(i), i * thumbW, 0, thumbW, getHeight(), null);
                    }
                    g2.setClip(null);
                    
                    if (!isCustomCover) {
                        int scrubberW = 30;
                        int px = (int)(coverPct * (getWidth() - scrubberW));
                        
                        g2.setColor(new Color(0, 0, 0, 80));
                        g2.setStroke(new BasicStroke(4f));
                        g2.drawRoundRect(px, 1, scrubberW, getHeight()-2, 6, 6);
                        
                        g2.setColor(WHITE);
                        g2.setStroke(new BasicStroke(2f));
                        g2.drawRoundRect(px, 1, scrubberW, getHeight()-2, 6, 6);
                    }
                }
                g2.dispose();
            }
        };
        coverTimeline.setPreferredSize(new Dimension(280, 50));
        coverTimeline.setMaximumSize(new Dimension(280, 50));
        coverTimeline.setCursor(Cursor.getPredefinedCursor(Cursor.HAND_CURSOR));
        MouseAdapter coverMouse = new MouseAdapter() {
            private void update(MouseEvent e) {
                isCustomCover = false;
                int scrubberW = 30;
                double pct = (double)(e.getX() - scrubberW/2) / (coverTimeline.getWidth() - scrubberW);
                coverPct = Math.max(0, Math.min(1, pct));
                coverTimeline.repaint();
                if (bgPanel != null) bgPanel.repaint();
                if (mediaPlayer != null) {
                    mediaPlayer.pause();
                    mediaPlayer.seek(mediaPlayer.getTotalDuration().multiply(coverPct));
                    if (coverFxView != null) coverFxView.setVisible(false);
                }
            }
            @Override public void mousePressed(MouseEvent e) { update(e); }
            @Override public void mouseDragged(MouseEvent e) { update(e); }
        };
        coverTimeline.addMouseListener(coverMouse);
        coverTimeline.addMouseMotionListener(coverMouse);
        coverTimeline.setAlignmentX(Component.LEFT_ALIGNMENT);
        panel.add(coverTimeline);
        panel.add(Box.createVerticalStrut(20));
        
        JSeparator sep2 = new JSeparator();
        sep2.setMaximumSize(new Dimension(Integer.MAX_VALUE, 1));
        panel.add(sep2);
        panel.add(Box.createVerticalStrut(15));
        
        JLabel lblOr = makeLabel("Hoặc chọn từ máy tính", 12, Font.PLAIN, TEXT_MUTED);
        lblOr.setAlignmentX(Component.LEFT_ALIGNMENT);
        panel.add(lblOr);
        panel.add(Box.createVerticalStrut(12));
        
        JButton btnPickCover = new JButton("   Tải lên") {
            { setIcon(new com.formdev.flatlaf.extras.FlatSVGIcon("images/icon/tailen.svg", 16, 16)); }
            @Override protected void paintComponent(Graphics g) {
                Graphics2D g2 = (Graphics2D) g.create();
                g2.setRenderingHint(RenderingHints.KEY_ANTIALIASING, RenderingHints.VALUE_ANTIALIAS_ON);
                g2.setColor(new Color(248, 243, 255));
                g2.fillRoundRect(0, 0, getWidth(), getHeight(), 12, 12);
                g2.setColor(new Color(216, 180, 254));
                g2.setStroke(new BasicStroke(1.2f));
                g2.drawRoundRect(0, 0, getWidth()-1, getHeight()-1, 12, 12);
                g2.dispose();
                super.paintComponent(g);
            }
        };
        btnPickCover.setFont(new Font("Segoe UI", Font.PLAIN, 13));
        btnPickCover.setForeground(PURPLE_MAIN);
        btnPickCover.setContentAreaFilled(false);
        btnPickCover.setBorderPainted(false);
        btnPickCover.setFocusPainted(false);
        btnPickCover.setOpaque(false);
        btnPickCover.setPreferredSize(new Dimension(120, 36));
        btnPickCover.setCursor(Cursor.getPredefinedCursor(Cursor.HAND_CURSOR));
        
        JPanel btnWrap = new JPanel(new FlowLayout(FlowLayout.LEFT, 0, 0));
        btnWrap.setOpaque(false);
        btnWrap.setAlignmentX(Component.LEFT_ALIGNMENT);
        btnWrap.add(btnPickCover);
        panel.add(btnWrap);
        panel.add(Box.createVerticalStrut(12));
        
        JLabel lblFormat = makeLabel("Định dạng: JPG, PNG • Kích thước tối đa: 5MB", 10, Font.PLAIN, new Color(156, 163, 175));
        lblFormat.setAlignmentX(Component.LEFT_ALIGNMENT);
        panel.add(lblFormat);
        panel.add(Box.createVerticalStrut(12));
        
        JLabel coverImgLabel = new JLabel() {
            @Override protected void paintComponent(Graphics g) {
                if (customCoverImg == null) return;
                Graphics2D g2 = (Graphics2D) g.create();
                g2.setRenderingHint(RenderingHints.KEY_ANTIALIASING, RenderingHints.VALUE_ANTIALIAS_ON);
                g2.setClip(new java.awt.geom.RoundRectangle2D.Float(0, 0, getWidth(), getHeight(), 8, 8));
                g2.drawImage(customCoverImg, 0, 0, getWidth(), getHeight(), null);
                g2.setClip(null);
                if (isCustomCover) {
                    g2.setColor(new Color(34, 197, 94, 40));
                    g2.fillRoundRect(0, 0, getWidth(), getHeight(), 8, 8);
                    g2.setColor(WHITE);
                    g2.setStroke(new BasicStroke(3.5f, BasicStroke.CAP_ROUND, BasicStroke.JOIN_ROUND));
                    int ccx = getWidth()/2;
                    int ccy = getHeight()/2;
                    g2.drawLine(ccx - 10, ccy, ccx - 3, ccy + 8);
                    g2.drawLine(ccx - 3, ccy + 8, ccx + 12, ccy - 8);
                }
                g2.setColor(new Color(255, 255, 255, 240));
                g2.fillOval(getWidth()-28, 8, 20, 20);
                g2.setColor(new Color(75, 85, 99));
                g2.setStroke(new BasicStroke(1.5f));
                g2.drawLine(getWidth()-23, 13, getWidth()-13, 23);
                g2.drawLine(getWidth()-13, 13, getWidth()-23, 23);
                g2.dispose();
            }
        };
        coverImgLabel.setPreferredSize(new Dimension(248, 140));
        coverImgLabel.setMaximumSize(new Dimension(248, 140));
        coverImgLabel.setVisible(false);
        coverImgLabel.setCursor(Cursor.getPredefinedCursor(Cursor.HAND_CURSOR));
        coverImgLabel.addMouseListener(new MouseAdapter() {
            @Override public void mousePressed(MouseEvent e) {
                if (e.getX() >= coverImgLabel.getWidth() - 32 && e.getY() <= 32) {
                    customCoverImg = null;
                    isCustomCover = false;
                    coverImgLabel.setVisible(false);
                    if (coverFxView != null) coverFxView.setVisible(false);
                } else {
                    isCustomCover = true;
                    if (mediaPlayer == null || mediaPlayer.getStatus() != MediaPlayer.Status.PLAYING) {
                        if (coverFxView != null) coverFxView.setVisible(true);
                    }
                }
                if (coverTimeline != null) coverTimeline.repaint();
                coverImgLabel.repaint();
            }
        });
        
        JPanel imgWrap = new JPanel(new FlowLayout(FlowLayout.LEFT, 0, 0));
        imgWrap.setOpaque(false);
        imgWrap.setAlignmentX(Component.LEFT_ALIGNMENT);
        imgWrap.add(coverImgLabel);
        panel.add(imgWrap);
        
        btnPickCover.addActionListener(e -> {
            JFileChooser chooser = new JFileChooser();
            if (chooser.showOpenDialog(UploadReelDialog.this) == JFileChooser.APPROVE_OPTION) {
                try {
                    customCoverImg = javax.imageio.ImageIO.read(chooser.getSelectedFile());
                    if (customCoverImg != null) {
                        isCustomCover = true;
                        coverImgLabel.setVisible(true);
                        coverImgLabel.repaint();
                        if (coverTimeline != null) coverTimeline.repaint();
                        bgPanel.revalidate();
                        bgPanel.repaint();
                        if (coverFxView != null) {
                            java.io.ByteArrayOutputStream bos = new java.io.ByteArrayOutputStream();
                            javax.imageio.ImageIO.write((java.awt.image.BufferedImage)customCoverImg, "png", bos);
                            coverFxView.setImage(new javafx.scene.image.Image(new java.io.ByteArrayInputStream(bos.toByteArray())));
                            if (mediaPlayer == null || mediaPlayer.getStatus() != MediaPlayer.Status.PLAYING) {
                                coverFxView.setVisible(true);
                            }
                        }
                    }
                } catch (Exception ex) { ex.printStackTrace(); }
            }
        });
        
        panel.add(Box.createVerticalStrut(20));
        JSeparator sep3 = new JSeparator();
        sep3.setMaximumSize(new Dimension(Integer.MAX_VALUE, 1));
        panel.add(sep3);
        panel.add(Box.createVerticalStrut(15));
        
        JPanel audioRow = new JPanel(new BorderLayout(8, 0));
        audioRow.setOpaque(false);
        audioRow.setMaximumSize(new Dimension(Integer.MAX_VALUE, 30));
        audioRow.setAlignmentX(Component.LEFT_ALIGNMENT);
        audioRow.add(makeLabel("Âm thanh", 15, Font.PLAIN, TEXT_MAIN), BorderLayout.WEST);
        
        JToggleButton btnMute = new JToggleButton() {
            @Override protected void paintComponent(Graphics g) {
                Graphics2D g2 = (Graphics2D) g.create();
                g2.setRenderingHint(RenderingHints.KEY_ANTIALIASING, RenderingHints.VALUE_ANTIALIAS_ON);
                if (isSelected()) {
                    g2.setColor(new Color(229, 231, 235));
                    g2.fillRoundRect(0, 0, 38, 20, 20, 20);
                    g2.setColor(WHITE);
                    g2.fillOval(2, 2, 16, 16);
                } else {
                    g2.setColor(new Color(216, 180, 254));
                    g2.fillRoundRect(0, 0, 38, 20, 20, 20);
                    g2.setColor(WHITE);
                    g2.fillOval(20, 2, 16, 16);
                }
                g2.dispose();
            }
        };
        btnMute.setPreferredSize(new Dimension(38, 20));
        btnMute.setContentAreaFilled(false);
        btnMute.setBorderPainted(false);
        btnMute.setFocusPainted(false);
        btnMute.setCursor(Cursor.getPredefinedCursor(Cursor.HAND_CURSOR));
        btnMute.addActionListener(e -> {
            isMuted = btnMute.isSelected();
            if (mediaPlayer != null) mediaPlayer.setMute(isMuted);
        });
        audioRow.add(btnMute, BorderLayout.EAST);
        panel.add(audioRow);
        
        JPanel outerWrap = new JPanel(new BorderLayout());
        outerWrap.setOpaque(false);
        outerWrap.add(bgPanel, BorderLayout.NORTH);
        return outerWrap;
    }
    // STEP 3 – Create reel info
    // ══════════════════════════════════════════════════════════════════════════
    private JPanel buildStep3() {
        JPanel root = new JPanel(new BorderLayout(0, 0));
        root.setOpaque(false);

        root.add(buildStep3Header(), BorderLayout.NORTH);

        JPanel body = new JPanel(new BorderLayout(24, 0));
        body.setOpaque(false);
        body.setBorder(new EmptyBorder(12, 24, 16, 24));

        // Left: vertical video preview
        body.add(buildVerticalVideoPreview(), BorderLayout.WEST);

        // Right: info panel
        body.add(buildReelInfoPanel(), BorderLayout.CENTER);

        root.add(body, BorderLayout.CENTER);
        return root;
    }

    private JPanel buildStep3Header() {
        JPanel hdr = new JPanel(new BorderLayout());
        hdr.setOpaque(false);
        hdr.setBorder(new EmptyBorder(6, 20, 6, 20));

        JButton btnBack = makeBackBtn(() -> goTo("step2"));
        hdr.add(btnBack, BorderLayout.WEST);

        JLabel title = makeLabel("Thước phim mới", 17, Font.BOLD, TEXT_MAIN);
        title.setHorizontalAlignment(SwingConstants.CENTER);
        hdr.add(title, BorderLayout.CENTER);

        JButton btnShare = makeShareBtn("Chia sẻ", () -> {
            caption  = txtCaption != null ? getCaptionText().trim() : "";
            hashtags = "";
            isApproved = true;
            disposeDialog();
        });
        hdr.add(btnShare, BorderLayout.EAST);
        return hdr;
    }

    private JPanel buildVerticalVideoPreview() {
        JPanel outer = new JPanel(new GridBagLayout());
        outer.setOpaque(false);

        step3VideoContainer = new JPanel() {
            @Override protected void paintComponent(Graphics g) {
                Graphics2D g2 = (Graphics2D) g.create();
                g2.setRenderingHint(RenderingHints.KEY_ANTIALIASING, RenderingHints.VALUE_ANTIALIAS_ON);
                g2.setColor(new Color(0x1C1C1E));
                g2.fillRoundRect(0, 0, getWidth(), getHeight(), 24, 24);
                g2.setColor(new Color(0x9CA3AF));
                g2.setStroke(new BasicStroke(5.0f));
                g2.drawRoundRect(2, 2, getWidth() - 5, getHeight() - 5, 22, 22);
                g2.dispose();
            }
        };
        step3VideoContainer.setOpaque(false);
        step3VideoContainer.setLayout(new OverlayLayout(step3VideoContainer));
        
        outer.add(step3VideoContainer, new GridBagConstraints());
        return outer;
    }

    private JPanel buildReelInfoPanel() {
        JPanel panel = new JPanel();
        panel.setLayout(new BoxLayout(panel, BoxLayout.Y_AXIS));
        panel.setOpaque(false);

        panel.add(Box.createVerticalGlue());

        // Caption textarea
