            @Override protected void paintComponent(Graphics g) {
                Graphics2D g2 = (Graphics2D) g.create();
                g2.setRenderingHint(RenderingHints.KEY_ANTIALIASING, RenderingHints.VALUE_ANTIALIAS_ON);
                g2.setColor(WHITE);
                g2.fillRoundRect(0, 0, getWidth(), getHeight(), 12, 12);
                g2.setColor(new Color(0xD1D5DB));
                g2.setStroke(new BasicStroke(1.5f));
                g2.drawRoundRect(1, 1, getWidth() - 3, getHeight() - 3, 12, 12);
                g2.dispose();
            }
        };
        captionCard.setOpaque(false);
        captionCard.setMaximumSize(new Dimension(Integer.MAX_VALUE, 200));
        captionCard.setPreferredSize(new Dimension(0, 200));
        captionCard.setBorder(new EmptyBorder(16, 16, 12, 16));

        txtCaption = new JTextPane();
        txtCaption.setOpaque(false);
        txtCaption.setBorder(null);
        txtCaption.setFont(new Font("Segoe UI", Font.PLAIN, 15));
        txtCaption.setForeground(new Color(0x9CA3AF));
        txtCaption.setCaretColor(new Color(0x8B5CF6));
        txtCaption.setText("Viết chú thích cho thước phim...");

        txtCaption.addFocusListener(new java.awt.event.FocusAdapter() {
            @Override public void focusGained(java.awt.event.FocusEvent e) {
                if (txtCaption.getText().equals("Viết chú thích cho thước phim...")) {
                    txtCaption.setText("");
                    txtCaption.setForeground(new Color(0x374151));
                }
            }
            @Override public void focusLost(java.awt.event.FocusEvent e) {
                if (txtCaption.getText().trim().isEmpty()) {
                    txtCaption.setText("Viết chú thích cho thước phim...");
                    txtCaption.setForeground(new Color(0x9CA3AF));
                }
            }
        });

        JScrollPane captionScroll = new JScrollPane(txtCaption);
        captionScroll.setBorder(null);
        captionScroll.setOpaque(false);
        captionScroll.getViewport().setOpaque(false);
        captionCard.add(captionScroll, BorderLayout.CENTER);

        JPanel captionBottom = new JPanel(new BorderLayout());
