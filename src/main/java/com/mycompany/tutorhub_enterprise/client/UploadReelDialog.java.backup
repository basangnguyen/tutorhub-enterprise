    public UploadReelDialog(JFrame parent) {
        super(parent, "", true);
        setUndecorated(true);
        if (parent != null) {
            setSize(parent.getSize());
            setLocation(parent.getLocation());
        } else {
            java.awt.GraphicsEnvironment ge = java.awt.GraphicsEnvironment.getLocalGraphicsEnvironment();
            java.awt.Rectangle bounds = ge.getMaximumWindowBounds();
            setSize(bounds.width, bounds.height);
            setLocationRelativeTo(null);
        }
        setBackground(new Color(0, 0, 0, 160));
        getRootPane().setBorder(BorderFactory.createEmptyBorder());

        // Wrap the shadow panel to keep it centered
        JPanel overlayWrapper = new JPanel(new GridBagLayout());
        overlayWrapper.setOpaque(false);

        // Outer shadow panel (acts as rounded container)
        shadow = new JPanel(new BorderLayout()) {
            @Override protected void paintComponent(Graphics g) {
                Graphics2D g2 = (Graphics2D) g.create();
                g2.setRenderingHint(RenderingHints.KEY_ANTIALIASING, RenderingHints.VALUE_ANTIALIAS_ON);
                // soft shadow
                g2.setColor(new Color(0, 0, 0, 20));
                for (int i = 0; i < 10; i++) {
                    g2.setColor(new Color(0, 0, 0, 3 + i));
                    g2.fillRoundRect(i, i + 4, getWidth() - i * 2, getHeight() - i * 2 - 4, 32, 32);
                }
                g2.setColor(WHITE);
                g2.fillRoundRect(10, 10, getWidth() - 20, getHeight() - 20, 28, 28);
                g2.dispose();
            }
        };
        shadow.setOpaque(false);
        shadow.setBorder(new EmptyBorder(14, 14, 14, 14));
        shadow.setPreferredSize(new Dimension(760, 580)); // Initial size for Step 1
        
        overlayWrapper.add(shadow);
        setContentPane(overlayWrapper);

        cardLayout = new CardLayout();
        cardPanel  = new JPanel(cardLayout);
        cardPanel.setOpaque(false);

        cardPanel.add(buildStep1(), "step1");
        cardPanel.add(buildStep2(), "step2");
        cardPanel.add(buildStep3(), "step3");

        shadow.add(cardPanel, BorderLayout.CENTER);
        cardLayout.show(cardPanel, "step1");

        // Entrance animation
        setOpacity(0f);
        Timer fadeIn = new Timer(16, null);
        final float[] op = {0f};
        fadeIn.addActionListener(e -> {
            op[0] += 0.07f;
            if (op[0] >= 1f) { op[0] = 1f; fadeIn.stop(); }
            setOpacity(op[0]);
        });
        fadeIn.start();
    }

    // ══════════════════════════════════════════════════════════════════════════
    // STEP 1 – Upload zone
    // ══════════════════════════════════════════════════════════════════════════
    private JPanel buildStep1() {
        JPanel root = new JPanel(new BorderLayout());
        root.setOpaque(false);

        // Close button (top-right)
        JPanel topBar = new JPanel(new BorderLayout());
        topBar.setOpaque(false);
        topBar.setBorder(new EmptyBorder(16, 0, 0, 16));
        JButton btnClose = makeCloseBtn();
        topBar.add(btnClose, BorderLayout.EAST);
        root.add(topBar, BorderLayout.NORTH);

        // Center content
        JPanel center = new JPanel();
        center.setLayout(new BoxLayout(center, BoxLayout.Y_AXIS));
        center.setOpaque(false);
        center.setBorder(new EmptyBorder(8, 48, 24, 48));

        JPanel zone = new JPanel() {
            @Override protected void paintComponent(Graphics g) {
                Graphics2D g2 = (Graphics2D) g.create();
                g2.setRenderingHint(RenderingHints.KEY_ANTIALIASING, RenderingHints.VALUE_ANTIALIAS_ON);
                g2.setColor(new Color(0xD3C6FE)); // Light purple dashed border
                g2.setStroke(new BasicStroke(1.2f, BasicStroke.CAP_ROUND, BasicStroke.JOIN_ROUND, 0, new float[]{8f, 6f}, 0));
                g2.drawRoundRect(0, 0, getWidth() - 1, getHeight() - 1, 24, 24);
                if (isDragOver) {
                    g2.setColor(new Color(139, 92, 246, 15));
                    g2.fillRoundRect(0, 0, getWidth(), getHeight(), 24, 24);
                }
                g2.dispose();
            }
        };
        zone.setLayout(new BoxLayout(zone, BoxLayout.Y_AXIS));
        zone.setOpaque(false);
        zone.setBorder(new EmptyBorder(50, 24, 50, 24));

        // Upload icon
        JLabel uploadIcon = new JLabel("");
        setIconFromUrlAsync(uploadIcon, "/images/icon/video_posting.png", 120, 120);
        uploadIcon.setAlignmentX(Component.CENTER_ALIGNMENT);
        zone.add(uploadIcon);
        zone.add(Box.createVerticalStrut(20));

        lblDropInstruction = makeLabel("Kéo & thả video vào đây", 22, Font.BOLD, new Color(0x1F2937));
        lblDropInstruction.setAlignmentX(Component.CENTER_ALIGNMENT);
        zone.add(lblDropInstruction);
        zone.add(Box.createVerticalStrut(8));

        lblDropSub = makeLabel("hoặc chọn tệp từ máy tính", 14, Font.PLAIN, new Color(0x6B7280));
        lblDropSub.setAlignmentX(Component.CENTER_ALIGNMENT);
        zone.add(lblDropSub);
        zone.add(Box.createVerticalStrut(24));

        // Choose button
        JButton btnChoose = buildChooseBtn();
        btnChoose.setAlignmentX(Component.CENTER_ALIGNMENT);
        zone.add(btnChoose);
        zone.add(Box.createVerticalStrut(10));
        
        lblFileError = makeLabel("", 13, Font.PLAIN, new Color(0xEF4444));
        lblFileError.setAlignmentX(Component.CENTER_ALIGNMENT);
        lblFileError.setVisible(false);
        zone.add(lblFileError);

        // Drag-and-drop support
        try {
            DropTarget dt = new DropTarget();
            dt.addDropTargetListener(new DropTargetAdapter() {
                @Override public void dragEnter(DropTargetDragEvent e) {
                    isDragOver = true;
                    lblDropInstruction.setText("Thả video để tải lên");
                    zone.repaint();
                }
                @Override public void dragExit(DropTargetEvent e) {
                    isDragOver = false;
                    lblDropInstruction.setText("Kéo & thả video vào đây");
                    zone.repaint();
                }
                @Override public void drop(DropTargetDropEvent e) {
                    isDragOver = false;
                    try {
                        e.acceptDrop(DnDConstants.ACTION_COPY);
                        @SuppressWarnings("unchecked")
                        List<File> files = (List<File>) e.getTransferable().getTransferData(DataFlavor.javaFileListFlavor);
                        if (!files.isEmpty()) {
                            handleFileSelected(files.get(0));
                        }
                    } catch (Exception ex) { ex.printStackTrace(); }
                    zone.repaint();
                }
            });
            zone.setDropTarget(dt);
        } catch (TooManyListenersException ignore) {}

        // Click to open chooser
        zone.addMouseListener(new MouseAdapter() {
            @Override public void mouseClicked(MouseEvent e) { openFileChooser(); }
            @Override public void mouseEntered(MouseEvent e) { zone.setCursor(Cursor.getPredefinedCursor(Cursor.HAND_CURSOR)); }
        });
        center.add(zone);
        center.add(Box.createVerticalGlue());
        root.add(center, BorderLayout.CENTER);
        root.add(buildFormatInfo(), BorderLayout.SOUTH);
        return root;
    }

    private JButton buildChooseBtn() {
        JButton btn = new JButton("  Chọn từ máy tính") {
            { setIcon(new com.formdev.flatlaf.extras.FlatSVGIcon("/images/icon/folder.svg", 20, 20)); }
            @Override protected void paintComponent(Graphics g) {
                Graphics2D g2 = (Graphics2D) g.create();
                g2.setRenderingHint(RenderingHints.KEY_ANTIALIASING, RenderingHints.VALUE_ANTIALIAS_ON);
                g2.setColor(getModel().isRollover() ? new Color(0x7C3AED) : PURPLE_MAIN);
                g2.fillRoundRect(0, 0, getWidth(), getHeight(), 12, 12);
                g2.dispose();
                super.paintComponent(g);
            }
        };
        btn.setFont(new Font("Segoe UI", Font.BOLD, 14));
        btn.setForeground(WHITE);
        btn.setContentAreaFilled(false);
        btn.setBorderPainted(false);
        btn.setFocusPainted(false);
        btn.setOpaque(false);
        btn.setCursor(Cursor.getPredefinedCursor(Cursor.HAND_CURSOR));
        btn.setPreferredSize(new Dimension(240, 44));
        btn.setMaximumSize(new Dimension(240, 44));
        btn.addActionListener(e -> openFileChooser());
        return btn;
    }

    private JPanel buildFormatInfo() {
        JPanel footer = new JPanel(new FlowLayout(FlowLayout.CENTER, 0, 24)) {
            @Override protected void paintComponent(Graphics g) {
                super.paintComponent(g);
                Graphics2D g2 = (Graphics2D) g.create();
                g2.setColor(new Color(0xE5E7EB));
                g2.drawLine(0, 0, getWidth(), 0);
                g2.dispose();
            }
        };
        footer.setOpaque(false);

        String[][] infos = {
            {"images/icon/MP4.svg", "MP4, MOV, WEBM"}, 
            {"images/icon/cloud.svg", "Tối đa 1GB"}, 
            {"images/icon/Clock.svg", "Tối đa 10 phút"}
        };
        for (int i = 0; i < infos.length; i++) {
            if (i > 0) {
                JPanel sep = new JPanel() {
                    @Override protected void paintComponent(Graphics g) {
                        g.setColor(new Color(0xE5E7EB));
                        g.drawLine(getWidth()/2, 4, getWidth()/2, getHeight()-4);
                    }
                };
                sep.setOpaque(false);
                sep.setPreferredSize(new Dimension(60, 20));
                footer.add(sep);
            }
            JLabel item = new JLabel("  " + infos[i][1]); 
            item.setIcon(new com.formdev.flatlaf.extras.FlatSVGIcon(infos[i][0], 20, 20));
            item.setFont(new Font("Segoe UI", Font.PLAIN, 13));
            item.setForeground(new Color(0x4B5563));
            footer.add(item);
        }
        return footer;
    }

