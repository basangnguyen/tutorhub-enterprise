        JLabel lblEmoji = makeLabel("", 13, Font.PLAIN, TEXT_MUTED);
        setIconFromUrlAsync(lblEmoji, "https://img.icons8.com/fluency-systems-regular/48/9CA3AF/happy.png", 20, 20);
        lblEmoji.setCursor(new Cursor(Cursor.HAND_CURSOR));
        lblEmoji.addMouseListener(new MouseAdapter() {
            @Override public void mouseClicked(MouseEvent e) {
                showEmojiPicker(lblEmoji);
